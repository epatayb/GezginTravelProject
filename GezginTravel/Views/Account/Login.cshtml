@using GezginTravel.DTOs.Auth
@model LoginDto

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="bg-background text-on-background font-body-md text-body-md h-screen w-full overflow-hidden flex flex-col md:flex-row">

    <!-- Sol Görsel Alanı - Mobilde Gizli -->
    <div class="hidden md:block md:w-1/2 h-full relative">
        <div class="absolute inset-0 bg-cover bg-center"
             style="background-image: url('/images/travel-login.png');">

            <div class="absolute inset-0 bg-black/20 flex flex-col justify-end p-margin-desktop">
                <div class="backdrop-blur-md bg-white/20 p-6 rounded-xl border border-white/30 max-w-md">
                    <span class="font-headline-md text-headline-md text-white mb-2 block">
                        Gezgin
                    </span>

                    <p class="font-body-md text-body-md text-white/90">
                        "Dünya bir kitaptır ve seyahat etmeyenler onun yalnızca bir sayfasını okur."</p>

                    <div class="font-body-md text-body-md text-white/90 mt-2 text-right">
                        Saint Augustine
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sağ Login Alanı -->
    <div class="w-full md:w-1/2 h-full flex items-center justify-center bg-surface p-margin-mobile md:p-margin-desktop overflow-y-auto">
        <div class="w-full max-w-md space-y-8">

            <!-- Başlık -->
            <div class="text-center">
                <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-2">
                    Hoş Geldin
                </h1>

                <p class="font-body-md text-body-md text-on-surface-variant">
                    Yolculuğuna devam etmek için giriş yap.
                </p>
            </div>

            <!-- Form -->
            <form asp-controller="Account" asp-action="Login" method="post" class="space-y-6 mt-8">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-sm text-error bg-error-container text-on-error-container rounded-lg p-3">
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email"
                           class="block font-label-caps text-label-caps text-on-surface-variant mb-2">
                        E-posta
                    </label>

                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-on-surface-variant"
                                  style="font-variation-settings: 'FILL' 0;">
                                mail
                            </span>
                        </div>

                        <input asp-for="Email"
                               autocomplete="email"
                               placeholder="ornek@gezgin.com"
                               class="block w-full pl-10 pr-3 py-3 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface placeholder-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md text-body-md" />
                    </div>

                    <span asp-validation-for="Email" class="text-sm text-error mt-1 block"></span>
                </div>

                <!-- Password -->
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <label asp-for="Password"
                               class="block font-label-caps text-label-caps text-on-surface-variant">
                            Şifre
                        </label>

                        <div class="text-sm">
                            <a asp-controller="Account"
                               asp-action="ForgotPassword"
                               class="font-body-md text-body-md text-primary hover:text-on-primary-container transition-colors text-sm">
                                Şifremi Unuttum?
                            </a>
                        </div>
                    </div>

                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-on-surface-variant"
                                  style="font-variation-settings: 'FILL' 0;">
                                lock
                            </span>
                        </div>

                        <input asp-for="Password"
                               autocomplete="current-password"
                               placeholder="••••••••"
                               class="block w-full pl-10 pr-3 py-3 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface placeholder-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md text-body-md" />
                    </div>

                    <span asp-validation-for="Password" class="text-sm text-error mt-1 block"></span>
                </div>

                <!-- Beni Hatırla -->
                <div class="flex items-center">
                    <input asp-for="RememberMe"
                           class="h-4 w-4 text-primary focus:ring-primary border-outline rounded cursor-pointer" />

                    <label asp-for="RememberMe"
                           class="ml-2 block font-body-md text-body-md text-on-surface-variant cursor-pointer">
                        Beni Hatırla
                    </label>
                </div>

                <!-- Giriş Butonu -->
                <div>
                    <button class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-lg shadow-sm font-body-md text-body-md font-bold text-on-primary bg-primary hover:bg-on-primary-container focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all active:scale-95"
                            type="submit">
                        Giriş Yap

                        <span class="material-symbols-outlined ml-2 text-sm"
                              style="font-variation-settings: 'FILL' 0;">
                            arrow_forward
                        </span>
                    </button>
                </div>
            </form>

            <!-- Ayırıcı -->
            <div class="mt-6">
                <div class="relative">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-outline-variant"></div>
                    </div>

                    <div class="relative flex justify-center text-sm">
                        <span class="px-2 bg-surface text-on-surface-variant font-body-md text-body-md text-sm">
                            veya şununla devam et
                        </span>
                    </div>
                </div>
            </div>

            <!-- Google Giriş -->
            <div class="mt-6">
                <a asp-controller="Account"
                   asp-action="ExternalLogin"
                   asp-route-provider="Google"
                   class="w-full flex justify-center items-center py-3 px-4 border border-outline-variant rounded-lg bg-surface-container-lowest font-body-md text-body-md text-on-surface hover:bg-surface-container-low focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all">

                    <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"></path>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
                    </svg>

                    Google ile Giriş Yap
                </a>
            </div>

            <!-- Kayıt Linki -->
            <div class="mt-8 text-center">
                <p class="font-body-md text-body-md text-on-surface-variant">
                    Hesabınız yok mu?

                    <a asp-controller="Account"
                       asp-action="Register"
                       class="font-body-md text-body-md font-bold text-primary hover:text-on-primary-container transition-colors">
                        Hesap Oluştur
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}