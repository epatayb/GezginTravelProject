@using GezginTravel.DTOs.Auth
@model RegisterDto

@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    input:focus {
        outline: none;
        border-color: #ff6b35 !important;
        box-shadow: 0 0 0 2px rgba(255, 107, 53, 0.1);
    }
</style>

<main class="flex min-h-screen bg-background text-on-surface font-body-md selection:bg-primary-container selection:text-on-primary-container">

    <!-- Sol Görsel Alanı - Mobilde Gizli -->
    <section class="hidden lg:flex lg:w-1/2 relative items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0 h-full w-full bg-cover bg-center"
             style="background-image: url('/images/register-bg.png')">
            <div class="absolute inset-0 bg-black/20"></div>
        </div>

        <div class="relative z-10 w-full max-w-md px-8">
            <div class="glass-card p-10 rounded-xl text-white shadow-2xl animate-fade-in">
                <h1 class="font-headline-md text-display-lg mb-4 tracking-tight">
                    Gezgin
                </h1>

                <p class="font-body-lg text-white/90 leading-relaxed">
                    Yeni rotalar keşfet, gezi deneyimlerini paylaş ve ilham veren yolculukların bir parçası ol.
                </p>
            </div>
        </div>
    </section>

    <!-- Sağ Kayıt Formu Alanı -->
    <section class="w-full lg:w-1/2 bg-surface flex items-center justify-center px-margin-mobile md:px-margin-desktop py-12 overflow-y-auto">
        <div class="w-full max-w-lg space-y-8">

            <div class="space-y-2">
                <div class="lg:hidden mb-8">
                    <span class="font-headline-md text-primary text-headline-md tracking-tighter">
                        Gezgin
                    </span>
                </div>

                <h1 class="font-headline-md text-display-lg-mobile md:text-headline-md text-on-surface">
                    Hesap Oluştur
                </h1>

                <p class="font-body-md text-on-surface-variant">
                    Gezgin topluluğuna katıl ve seyahat deneyimlerini paylaşmaya başla.
                </p>
            </div>

            <form asp-controller="Account"
                  asp-action="Register"
                  method="post"
                  enctype="multipart/form-data"
                  class="space-y-5">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-sm text-error bg-error-container text-on-error-container rounded-lg p-3">
                </div>

                <!-- Ad Soyad -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                    <div class="space-y-1.5">
                        <label asp-for="FirstName"
                               class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">
                            Ad
                        </label>

                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">
                                person
                            </span>

                            <input asp-for="FirstName"
                                   placeholder="Adınız"
                                   class="w-full pl-10 pr-4 py-3 bg-surface-container-low border border-outline-variant rounded-lg font-body-md transition-all focus:bg-white" />
                        </div>

                        <span asp-validation-for="FirstName" class="text-sm text-error"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label asp-for="LastName"
                               class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">
                            Soyad
                        </label>

                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">
                                badge
                            </span>

                            <input asp-for="LastName"
                                   placeholder="Soyadınız"
                                   class="w-full pl-10 pr-4 py-3 bg-surface-container-low border border-outline-variant rounded-lg font-body-md transition-all focus:bg-white" />
                        </div>

                        <span asp-validation-for="LastName" class="text-sm text-error"></span>
                    </div>

                </div>

                <!-- Kullanıcı Adı -->
                <div class="space-y-1.5">
                    <label asp-for="UserName"
                           class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">
                        Kullanıcı Adı
                    </label>

                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">
                            alternate_email
                        </span>

                        <input asp-for="UserName"
                               placeholder="gezgin_rotasi"
                               class="w-full pl-10 pr-4 py-3 bg-surface-container-low border border-outline-variant rounded-lg font-body-md transition-all focus:bg-white" />
                    </div>

                    <span asp-validation-for="UserName" class="text-sm text-error"></span>
                </div>

                <!-- E-posta -->
                <div class="space-y-1.5">
                    <label asp-for="Email"
                           class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">
                        E-posta Adresi
                    </label>

                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">
                            mail
                        </span>

                        <input asp-for="Email"
                               autocomplete="email"
                               placeholder="ornek@gezgin.com"
                               class="w-full pl-10 pr-4 py-3 bg-surface-container-low border border-outline-variant rounded-lg font-body-md transition-all focus:bg-white" />
                    </div>

                    <span asp-validation-for="Email" class="text-sm text-error"></span>
                </div>

                <!-- Profil Fotoğrafı -->
                <div class="space-y-2">
                    <label asp-for="Photo"
                           class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">
                        Profil Fotoğrafı
                    </label>

                    <div class="flex items-center gap-4 p-4 bg-surface-container-low border border-dashed border-outline rounded-lg">
                        <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center text-on-surface-variant flex-shrink-0">
                            <span class="material-symbols-outlined text-[32px]">
                                add_a_photo
                            </span>
                        </div>

                        <div class="space-y-1">
                            <label for="ProfileImage"
                                   class="text-primary font-bold text-sm hover:underline cursor-pointer">
                                Fotoğraf Yükle
                            </label>

                            <p class="text-xs text-on-surface-variant">
                                JPG, PNG veya WEBP. En fazla 2MB.
                            </p>

                            <input asp-for="Photo"
                                   id="Photo"
                                   type="file"
                                   accept=".jpg,.jpeg,.png,.webp"
                                   class="hidden" />
                        </div>
                    </div>

                    <span asp-validation-for="Photo" class="text-sm text-error"></span>
                </div>

                <!-- Şifreler -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                    <div class="space-y-1.5">
                        <label asp-for="Password"
                               class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">
                            Şifre
                        </label>

                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">
                                lock
                            </span>

                            <input asp-for="Password"
                                   autocomplete="new-password"
                                   placeholder="••••••••"
                                   class="w-full pl-10 pr-4 py-3 bg-surface-container-low border border-outline-variant rounded-lg font-body-md transition-all focus:bg-white" />
                        </div>

                        <span asp-validation-for="Password" class="text-sm text-error"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label asp-for="ConfirmPassword"
                               class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">
                            Şifre Tekrar
                        </label>

                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">
                                lock_reset
                            </span>

                            <input asp-for="ConfirmPassword"
                                   autocomplete="new-password"
                                   placeholder="••••••••"
                                   class="w-full pl-10 pr-4 py-3 bg-surface-container-low border border-outline-variant rounded-lg font-body-md transition-all focus:bg-white" />
                        </div>

                        <span asp-validation-for="ConfirmPassword" class="text-sm text-error"></span>
                    </div>

                </div>

                <!-- Kullanım Şartları -->
                <!-- Gizlilik Politikası Modal Aç/Kapat Kontrolü -->
                <input type="checkbox" id="privacyModalToggle" class="peer/privacyModal hidden" />

                <!-- Kullanım Şartları -->
                <div class="flex items-start gap-3 py-2">
                    <div class="flex items-center h-5">
                        <input asp-for="AcceptTerms"
                               id="AcceptTerms"
                               class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary-container cursor-pointer transition-colors" />
                    </div>

                    <p class="text-sm text-on-surface-variant leading-tight">
                        <label for="AcceptTerms" class="cursor-pointer">
                            Kullanım şartlarını ve
                        </label>

                        <label for="privacyModalToggle"
                               class="text-secondary font-bold hover:underline cursor-pointer">
                            gizlilik politikasını
                        </label>

                        <label for="AcceptTerms" class="cursor-pointer">
                            kabul ediyorum
                        </label>
                    </p>
                </div>

                <span asp-validation-for="AcceptTerms" class="text-sm text-error"></span>

                <!-- Gizlilik Politikası Modal -->
                <div class="fixed inset-0 z-50 hidden peer-checked/privacyModal:flex items-center justify-center px-4 bg-black/50 backdrop-blur-sm">

                    <div class="w-full max-w-2xl max-h-[85vh] overflow-hidden rounded-xl bg-surface text-on-surface shadow-2xl border border-outline-variant">

                        <!-- Modal Header -->
                        <div class="flex items-center justify-between px-6 py-4 border-b border-outline-variant">
                            <div>
                                <h3 class="font-headline-md text-headline-md text-on-surface">
                                    Gizlilik Politikası
                                </h3>
                                <p class="text-sm text-on-surface-variant mt-1">
                                    Son güncelleme: @DateTime.Now.ToString("dd.MM.yyyy")
                                </p>
                            </div>

                            <label for="privacyModalToggle"
                                   class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-surface-container-low cursor-pointer transition-colors">
                                <span class="material-symbols-outlined text-on-surface-variant">
                                    close
                                </span>
                            </label>
                        </div>

                        <!-- Modal Body -->
                        <div class="px-6 py-5 overflow-y-auto max-h-[60vh] space-y-5 text-sm leading-relaxed text-on-surface-variant">

                            <div>
                                <h4 class="font-bold text-on-surface mb-2">1. Genel Bilgilendirme</h4>
                                <p>
                                    Bu Gizlilik Politikası, Gezgin platformuna üye olurken ve platformu kullanırken
                                    paylaştığınız kişisel verilerin hangi amaçlarla işlendiğini açıklamak için hazırlanmıştır.
                                    Gezgin; seyahat deneyimlerinin paylaşılması, kullanıcı hesabı oluşturulması ve platform
                                    güvenliğinin sağlanması amacıyla bazı kişisel verileri işleyebilir.
                                </p>
                            </div>

                            <div>
                                <h4 class="font-bold text-on-surface mb-2">2. İşlenen Kişisel Veriler</h4>
                                <p>
                                    Kayıt sırasında ad, soyad, kullanıcı adı, e-posta adresi, şifre bilgisi ve profil fotoğrafı 
                                    işlenebilir. Şifre bilgileriniz güvenli şekilde saklanmalı,
                                    düz metin olarak tutulmamalıdır.
                                </p>
                            </div>

                            <div>
                                <h4 class="font-bold text-on-surface mb-2">3. Kişisel Verilerin İşlenme Amaçları</h4>
                                <p>
                                    Kişisel verileriniz; kullanıcı hesabı oluşturmak, giriş işlemlerini sağlamak, profil
                                    bilgilerinizi göstermek, blog ve yorum işlemlerini kullanıcı hesabınızla ilişkilendirmek,
                                    güvenliği sağlamak ve gerektiğinde sizinle iletişime geçmek amacıyla işlenebilir.
                                </p>
                            </div>

                            <div>
                                <h4 class="font-bold text-on-surface mb-2">4. Profil Fotoğrafı Kullanımı</h4>
                                <p>
                                    Profil fotoğrafı yüklerseniz, bu fotoğraf kullanıcı profilinizde ve platform içerisindeki
                                    ilgili alanlarda görüntülenebilir.
                                </p>
                            </div>

                            <div>
                                <h4 class="font-bold text-on-surface mb-2">5. Verilerin Aktarılması</h4>
                                <p>
                                    Kişisel verileriniz, yasal zorunluluklar dışında üçüncü kişilerle paylaşılmaz. Ancak
                                    uygulamanın çalışması için barındırma, e-posta gönderimi, güvenlik ve teknik altyapı
                                    hizmetleri kapsamında hizmet sağlayıcılarla sınırlı şekilde paylaşılabilir.
                                </p>
                            </div>

                            <div>
                                <h4 class="font-bold text-on-surface mb-2">6. Verilerin Saklanması</h4>
                                <p>
                                    Kişisel verileriniz, hesabınız aktif olduğu sürece veya ilgili mevzuatta öngörülen süreler
                                    boyunca saklanabilir. Hesabınızın silinmesini talep etmeniz halinde, yasal saklama
                                    yükümlülükleri dışında verileriniz silinebilir veya anonim hale getirilebilir.
                                </p>
                            </div>

                            <div>
                                <h4 class="font-bold text-on-surface mb-2">7. Kullanıcı Hakları</h4>
                                <p>
                                    KVKK kapsamında kişisel verilerinizin işlenip işlenmediğini öğrenme, işlenmişse bilgi talep
                                    etme, eksik veya yanlış işlenmiş verilerin düzeltilmesini isteme, şartları oluşmuşsa
                                    silinmesini veya yok edilmesini talep etme haklarına sahipsiniz.
                                </p>
                            </div>

                            <div>
                                <h4 class="font-bold text-on-surface mb-2">8. İletişim</h4>
                                <p>
                                    Gizlilik politikası ve kişisel verilerinizle ilgili talepleriniz için bizimle iletişime
                                    geçebilirsiniz.
                                </p>
                                <p class="mt-2">
                                    E-posta: <span class="font-bold text-on-surface">info@gezgin.com</span>
                                </p>
                            </div>

                            <div class="p-4 rounded-lg bg-surface-container-low border border-outline-variant">
                                <p class="text-xs">
                                    Not: Bu metin proje geliştirme amacıyla hazırlanmış örnek bir metindir. Gerçek yayına alma
                                    aşamasında, proje sahibinin bilgileri, veri işleme süreçleri, kullanılan servisler ve hukuki
                                    gerekliliklere göre güncellenmelidir.
                                </p>
                            </div>

                        </div>

                        <!-- Modal Footer -->
                        <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-outline-variant bg-surface-container-lowest">

                            <label for="privacyModalToggle"
                                   class="px-5 py-2 rounded-lg border border-outline-variant text-on-surface font-bold cursor-pointer hover:bg-surface-container-low transition-colors">
                                Kapat
                            </label>

                            <label for="privacyModalToggle"
                                   class="px-5 py-2 rounded-lg bg-primary text-on-primary font-bold cursor-pointer hover:bg-on-primary-container transition-colors">
                                Okudum
                            </label>

                        </div>
                    </div>
                </div>

                <!-- Kayıt Butonu -->
                <button class="w-full py-4 bg-primary text-on-primary font-headline-md rounded-lg shadow-lg shadow-primary/20 hover:scale-[1.01] active:scale-[0.98] transition-all duration-200 mt-4"
                        type="submit">
                    Hesap Oluştur
                </button>

                <!-- Giriş Linki -->
                <div class="pt-6 text-center border-t border-outline-variant">
                    <p class="text-on-surface-variant font-body-md">
                        Zaten hesabın var mı?

                        <a asp-controller="Account"
                           asp-action="Login"
                           class="text-primary font-bold ml-1 hover:underline decoration-primary-container decoration-2 underline-offset-4">
                            Giriş Yap
                        </a>
                    </p>
                </div>

            </form>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Simple animation trigger for the left card
        document.addEventListener('DOMContentLoaded', () => {
            const card = document.querySelector('.glass-card');
            if(card) {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, 200);
            }
        });

        // Hover effect for input icons
        const inputs = document.querySelectorAll('input');
        inputs.forEach(input => {
            input.addEventListener('focus', () => {
                const icon = input.previousElementSibling;
                if(icon) icon.classList.add('text-primary');
            });
            input.addEventListener('blur', () => {
                const icon = input.previousElementSibling;
                if(icon) icon.classList.remove('text-primary');
            });
        });
    </script>
}