@using Microsoft.AspNetCore.Identity
@using GezginTravel.Models.Identity
@inject UserManager<AppUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);

    var fullName = currentUser == null
        ? "Admin"
        : $"{currentUser.FirstName} {currentUser.LastName}";

    var photoUrl = string.IsNullOrWhiteSpace(currentUser?.PhotoUrl)
        ? "/uploads/users/default-user.png"
        : currentUser.PhotoUrl;
}

<header class="bg-surface shadow-sm fixed top-0 right-0 h-16 flex items-center justify-between px-4 md:px-10 z-30 w-full md:w-[calc(100%-16rem)]">

    <div class="flex items-center gap-4 flex-1">
        <button id="menuBtn" class="md:hidden text-on-surface-variant focus:outline-none">
            <span class="material-symbols-outlined">menu</span>
        </button>

        <div class="relative w-full max-w-md hidden sm:block">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">
                search
            </span>

            <input class="w-full bg-surface-container rounded-full py-2 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-primary border-none"
                   placeholder="Ara..."
                   type="text" />
        </div>
    </div>

    <div class="flex items-center gap-4">

        <button class="text-on-surface-variant hover:text-primary transition-colors relative">
            <span class="material-symbols-outlined">notifications</span>
            <span class="absolute top-0 right-0 w-2 h-2 bg-primary rounded-full"></span>
        </button>

        <div class="flex items-center gap-3 border-l border-surface-variant pl-4">
            <div class="text-right hidden sm:block">
                <p class="text-sm font-bold text-on-surface">
                    @fullName
                </p>

                <p class="text-xs text-on-surface-variant uppercase tracking-wide">
                    Admin
                </p>
            </div>

            <div class="w-10 h-10 rounded-full border-2 border-surface-container overflow-hidden">
                <img class="w-full h-full object-cover"
                     src="/uploads/users/@photoUrl"
                     alt="@fullName" />
            </div>
        </div>
    </div>
</header>