
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Gezgin Travel Admin </title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&amp;family=Montserrat:wght@600;700&amp;display=swap" rel="stylesheet" />

    <script id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                "colors": {
                        "on-primary": "#ffffff",
                        "on-tertiary-fixed-variant": "#52443d",
                        "on-surface-variant": "#594139",
                        "background": "#fcf9f8",
                        "surface-container": "#f0eded",
                        "on-secondary-fixed": "#001c37",
                        "secondary-container": "#87bcfe",
                        "on-tertiary-fixed": "#241913",
                        "on-tertiary-container": "#3c2f28",
                        "error": "#ba1a1a",
                        "secondary": "#24619d",
                        "outline": "#8d7168",
                        "primary-fixed": "#ffdbd0",
                        "surface": "#fcf9f8",
                        "on-secondary": "#ffffff",
                        "tertiary-fixed-dim": "#d7c2b9",
                        "surface-bright": "#fcf9f8",
                        "on-secondary-fixed-variant": "#004880",
                        "inverse-on-surface": "#f3f0ef",
                        "on-surface": "#1c1b1b",
                        "surface-variant": "#e5e2e1",
                        "tertiary-fixed": "#f4ded4",
                        "secondary-fixed": "#d2e4ff",
                        "on-background": "#1c1b1b",
                        "primary": "#ab3500",
                        "on-tertiary": "#ffffff",
                        "on-secondary-container": "#004b84",
                        "surface-dim": "#dcd9d9",
                        "on-primary-fixed-variant": "#832600",
                        "inverse-surface": "#313030",
                        "primary-fixed-dim": "#ffb59d",
                        "outline-variant": "#e1bfb5",
                        "on-primary-container": "#5f1900",
                        "on-primary-fixed": "#390c00",
                        "secondary-fixed-dim": "#a1c9ff",
                        "tertiary-container": "#a9968d",
                        "inverse-primary": "#ffb59d",
                        "surface-container-highest": "#e5e2e1",
                        "error-container": "#ffdad6",
                        "surface-tint": "#ab3500",
                        "on-error-container": "#93000a",
                        "on-error": "#ffffff",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low": "#f6f3f2",
                        "surface-container-high": "#eae7e7",
                        "primary-container": "#ff6b35",
                        "tertiary": "#6b5b53"
                },
                "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                },
                "spacing": {
                        "margin-desktop": "40px",
                        "container-max": "1280px",
                        "base": "8px",
                        "margin-mobile": "16px",
                        "gutter": "24px"
                },
                "fontFamily": {
                        "body-lg": [
                                "Inter"
                        ],
                        "headline-md": [
                                "Montserrat"
                        ],
                        "display-lg": [
                                "Montserrat"
                        ],
                        "body-md": [
                                "Inter"
                        ],
                        "label-caps": [
                                "Inter"
                        ],
                        "display-lg-mobile": [
                                "Montserrat"
                        ]
                },
                "fontSize": {
                        "body-lg": [
                                "18px",
                                {
                                        "lineHeight": "28px",
                                        "fontWeight": "400"
                                }
                        ],
                        "headline-md": [
                                "24px",
                                {
                                        "lineHeight": "32px",
                                        "fontWeight": "600"
                                }
                        ],
                        "display-lg": [
                                "48px",
                                {
                                        "lineHeight": "56px",
                                        "letterSpacing": "-0.02em",
                                        "fontWeight": "700"
                                }
                        ],
                        "body-md": [
                                "16px",
                                {
                                        "lineHeight": "24px",
                                        "fontWeight": "400"
                                }
                        ],
                        "label-caps": [
                                "12px",
                                {
                                        "lineHeight": "16px",
                                        "letterSpacing": "0.05em",
                                        "fontWeight": "700"
                                }
                        ],
                        "display-lg-mobile": [
                                "32px",
                                {
                                        "lineHeight": "40px",
                                        "letterSpacing": "-0.01em",
                                        "fontWeight": "700"
                                }
                        ]
                }
        },
            },
          }
    </script>
</head>

<body class="bg-background text-on-background font-body-md antialiased overflow-x-hidden min-h-screen">

    @await Html.PartialAsync("~/Views/Admin/Shared/_AdminSidebar.cshtml")

    <div class="md:ml-64 min-h-screen flex flex-col bg-surface-container-lowest">

        @await Html.PartialAsync("~/Views/Admin/Shared/_AdminTopbar.cshtml")

        <main class="flex-1 mt-16 p-4 md:p-10 max-w-[1280px] mx-auto w-full">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/admin-sidebar.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>