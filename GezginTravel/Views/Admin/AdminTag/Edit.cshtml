@model GezginTravel.ViewModels.Dashboard.Admin.AdminTag.AdminTagEditViewModel

@{
    ViewData["Title"] = "Etiket Düzenle";
    Layout = "~/Views/Admin/Shared/_AdminLayout.cshtml";
}

<div class="mb-8">
    <a asp-controller="AdminTag" asp-action="Index"
       class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors mb-4">
        <span class="material-symbols-outlined text-[20px]">arrow_back</span>
        Etiket listesine dön
    </a>

    <h2 class="font-montserrat text-3xl font-bold text-on-background">
        Etiket Düzenle
    </h2>

    <p class="text-on-surface-variant mt-1">
        Etiket bilgilerini güncelle.
    </p>
</div>

<div class="bg-surface rounded-xl shadow-sm border border-surface-variant p-6 max-w-2xl">
    <form asp-controller="AdminTag" asp-action="Edit" asp-route-id="@Model.Id" method="post" class="space-y-5">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-error"></div>

        <div>
            <label asp-for="Name" class="block text-sm font-bold text-on-surface mb-2">
                Etiket Adı
            </label>

            <input asp-for="Name"
                   class="w-full rounded-lg border border-outline-variant bg-surface px-4 py-3 focus:border-primary focus:ring-primary" />

            <span asp-validation-for="Name" class="text-error text-sm"></span>
        </div>

        <div>
            <label class="block text-sm font-bold text-on-surface mb-2">
                Mevcut Slug
            </label>

            <input value="@Model.Slug"
                   disabled
                   class="w-full rounded-lg border border-outline-variant bg-surface-container px-4 py-3 text-on-surface-variant" />

            <p class="text-xs text-on-surface-variant mt-2">
                Etiket adı güncellenirse slug otomatik yeniden oluşturulur.
            </p>
        </div>

        <div class="flex items-center justify-end gap-3">
            <a asp-controller="AdminTag" asp-action="Index"
               class="px-5 py-2.5 rounded-full border border-outline-variant text-on-surface-variant font-bold hover:bg-surface-variant transition-colors">
                Vazgeç
            </a>

            <button type="submit"
                    class="px-6 py-2.5 rounded-full bg-primary text-on-primary font-bold hover:bg-primary-container hover:text-on-primary-container transition-colors">
                Güncelle
            </button>
        </div>
    </form>
</div>