@model GezginTravel.Models.Identity.AppUser

@{
    ViewData["Title"] = "Kullanıcı Detayı";
    Layout = "~/Views/Admin/Shared/_AdminLayout.cshtml";
}

<h2 class="text-3xl font-bold mb-6">Kullanıcı Detayı</h2>

<div class="bg-surface rounded-xl border border-surface-variant p-6">
    <p><strong>Ad Soyad:</strong> @Model.FirstName @Model.LastName</p>
    <p><strong>Kullanıcı Adı:</strong> @Model.UserName</p>
    <p><strong>E-posta:</strong> @Model.Email</p>
    <p><strong>Title:</strong> @Model.Title</p>
    <p><strong>Hakkında:</strong> @Model.About</p>
</div>

<a asp-action="Index" asp-controller="AdminUser" class="inline-block mt-4 text-primary font-bold">
    Kullanıcı listesine dön
</a>