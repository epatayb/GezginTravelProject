            <img alt="Hero background" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA8CCuggXavUOKw-OQwuTKr2z_L1IFt4IOJTg14tYrN2q-kCXZUczESePggSPBYjatxZqtAHB81IhNzzkTZnJ5UNca-lwYLLbKhQK7wh1EkYjlWQWNxdEtUvHqrZQ0GSYNwfiGjhfHbXI2BPkvUpWw-UPu7V9OihEjbc0yB_FNefZfA-kKxMuOnaLATgBV3wUzQ7CLWMNz7Dv5EPY9t0FBIfZgl98lqG-swkn5n0r8wjaNO_tYcVYDVGL1POzO9R6ZxpA3ZA5-BSk2Z" />
