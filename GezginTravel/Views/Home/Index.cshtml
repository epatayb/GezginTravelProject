                    <div class="flex items-center gap-3 mb-4">
                        <span class="material-symbols-outlined text-primary bg-white/20 p-1.5 rounded-full backdrop-blur-md" data-icon="map">map</span>
                        <span class="font-label-caps text-label-caps tracking-widest uppercase text-white/90">Dolomites, Italy • 4 Day Route</span>
                    </div>
                    <h3 class="font-display-lg-mobile text-display-lg-mobile leading-tight mb-4 group-hover:text-primary-fixed-dim transition-colors">
